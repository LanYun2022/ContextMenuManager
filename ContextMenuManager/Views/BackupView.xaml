<UserControl
    x:Class="ContextMenuManager.Views.BackupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock
                    x:Name="PageTitleText"
                    FontSize="22"
                    FontWeight="SemiBold" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            x:Name="SummaryLabel"
                            FontSize="15"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="SummaryHintText"
                            Margin="0,4,0,0"
                            FontSize="12"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button
                            x:Name="NewBackupButton"
                            Padding="14,7"
                            Click="NewBackupButton_OnClick" />
                        <Button
                            x:Name="OpenBackupFolderButton"
                            Margin="12,0,0,0"
                            Padding="14,7"
                            Click="OpenBackupFolderButton_OnClick" />
                        <Button
                            x:Name="RefreshButton"
                            Margin="12,0,0,0"
                            Padding="14,7"
                            Click="RefreshButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Margin="0,20,0,0"
                Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="BackupsHeaderText"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <DataGrid
                        x:Name="BackupsGrid"
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding BackupEntries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding DisplayText}"
                                Header="Backup" />
                            <DataGridTextColumn
                                Width="180"
                                Binding="{Binding DeviceName}"
                                Header="Device" />
                            <DataGridTextColumn
                                Width="180"
                                Binding="{Binding CreateTimeText}"
                                Header="Created" />
                            <DataGridTemplateColumn Width="210" Header="Actions">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button
                                                Padding="10,4"
                                                Click="RestoreBackupButton_OnClick"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Restore, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <Button
                                                Margin="8,0,0,0"
                                                Padding="10,4"
                                                Click="DeleteBackupButton_OnClick"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Delete, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
