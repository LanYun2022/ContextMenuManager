<UserControl
    x:Class="ContextMenuManager.Views.DonateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" HorizontalAlignment="Center">
                <TextBlock
                    x:Name="DonateInfoText"
                    MaxWidth="680"
                    FontSize="15"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

                <Border Margin="0,24,0,0" Style="{StaticResource CardStyle}">
                    <Image
                        x:Name="QrImage"
                        Width="420"
                        Height="140"
                        Cursor="Hand"
                        MouseLeftButtonUp="QrImage_OnMouseLeftButtonUp"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="Uniform" />
                </Border>

                <Image
                    x:Name="BuyMeCoffeeImage"
                    Width="151"
                    Height="38"
                    Cursor="Hand"
                    MouseLeftButtonUp="BuyMeCoffeeImage_OnMouseLeftButtonUp"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Stretch="Uniform" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
